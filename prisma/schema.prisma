// MysticVerse Global — data layer (Phase 1)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────
enum SubmissionStatus {
  NEW
  READ
  ARCHIVED
}

enum EnquiryType {
  SPONSOR
  EXHIBIT
  DELEGATE
  PRESS
  HR
  OTHER
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum UserRole {
  ADMIN
  EDITOR
}

// ── Admin users ────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(ADMIN)
  posts        Post[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Contact form submissions ───────────────────────────────
model ContactSubmission {
  id           String           @id @default(cuid())
  name         String
  email        String
  phone        String?
  country      String?
  organisation String?
  enquiryType  EnquiryType      @default(OTHER)
  message      String
  status       SubmissionStatus @default(NEW)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime         @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Delegate / registration interest submissions ───────────
model InterestSubmission {
  id        String           @id @default(cuid())
  name      String
  email     String
  phone     String?
  country   String?
  passType  String? // Delegate, HNI, Corporate, Investor, etc.
  company   String?
  message   String?
  status    SubmissionStatus @default(NEW)
  ipAddress String?
  userAgent String?
  createdAt DateTime         @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Pavilion Brief requests (partner enquiries) ────────────
model PavilionBriefRequest {
  id           String           @id @default(cuid())
  name         String
  email        String
  company      String?
  role         String?
  phone        String?
  country      String?
  tierInterest String? // Title Partner, Real Estate Booth, Retail Curation, Sustainable Living, Undecided
  message      String?
  status       SubmissionStatus @default(NEW)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime         @default(now())

  @@index([status])
  @@index([createdAt])
}

// ── Blog posts (Tiptap rich-text content) ──────────────────
model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String // Tiptap HTML
  coverImage  String?
  status      PostStatus @default(DRAFT)
  tags        String[]
  author      User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
}
