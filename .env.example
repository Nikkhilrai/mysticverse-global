# ── Database (Neon Postgres) ───────────────────────────────
# DATABASE_URL  → POOLED connection (used by the app at runtime).
#                 On Neon this is the "Pooled connection" string
#                 (host contains "-pooler"), with ?sslmode=require.
# DIRECT_URL    → DIRECT connection (used only for migrations).
#                 On Neon this is the standard connection string
#                 (no "-pooler"), with ?sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── Admin auth ─────────────────────────────────────────────
# Secret used to sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=""

# ── Email notifications (added in Phase 2) ─────────────────
# RESEND_API_KEY=""

# ── Blob storage for blog images (added in Phase 5) ────────
# BLOB_READ_WRITE_TOKEN=""
